arduino/Gridflow/build/
arduino/Gridflow/*.tmp
arduino/Gridflow/*.bak
arduino/Gridflow/*.hex
arduino/Gridflow/*.elf
arduino/Gridflow/*.bin
arduino/Gridflow/*.map

# --- OS & Junk Files ---
desktop.ini
Thumbs.db
.DS_Store

# --- Environment & IDE ---
.env
venv/
.vscode/
.idea/

# --- Configs (Keep the example, ignore the real one) ---
# This ensures your personal paths and settings stay local
config.json